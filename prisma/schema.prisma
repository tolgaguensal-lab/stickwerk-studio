generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LeadStatus {
  NEW
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model Lead {
  id               String     @id @default(cuid())
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  name             String
  email            String
  phone            String?
  message          String?
  calculationData  Json
  status           LeadStatus @default(NEW)
}
