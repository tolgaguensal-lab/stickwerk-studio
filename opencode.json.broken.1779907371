{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "arliai": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "ArliAI",
      "options": {
        "baseURL": "https://api.arliai.com/v1",
        "apiKey": "{env:ARLIAI_API_KEY}"
      },
      "models": {
        "Qwen3.5-27B-Omega-Evolution-v2.2-Derestricted-Lite": {
          "name": "Qwen3.5 27B Omega Evolution",
          "limit": {
            "context": 262144,
            "output": 32768
          }
        }
      }
    }
  },
  "model": "arliai/Qwen3.5-27B-Omega-Evolution-v2.2-Derestricted-Lite",
  "tools": {
    "github": {
      "enabled": true,
      "permissions": {
        "contents": "write",
        "pull_requests": "write",
        "issues": "write",
        "repository_projects": "write",
        "metadata": "read"
      }
    }
  }
}
