# ============================================
# Stickwerk-Studio Environment Variables
# ============================================
# Copy this to .env and fill in your values

# === POCKETBASE (installed via ZimaOS App Store) ===
# Replace <ZIMAOS-IP> with your ZimaOS IP address
NEXT_PUBLIC_POCKETBASE_URL=http://<ZIMAOS-IP>:8090
POCKETBASE_URL=http://127.0.0.1:8090
POCKETBASE_ADMIN_EMAIL=admin@stickwerk-studio.de
POCKETBASE_ADMIN_PASSWORD=your_admin_password_here

# === AUTH / SESSION (protects /admin routes) ===
# SESSION_SECRET: At least 32 characters, used to sign session cookies
SESSION_SECRET=your-secret-key-at-least-32-characters-long
# Admin credentials for the login form
ADMIN_USER=admin@stickwerk-studio.de
ADMIN_PASSWORD=your_secure_admin_password

# === SITE URLs ===
NEXT_PUBLIC_SITE_URL=https://sws.guenlab.de
NEXT_PUBLIC_APP_URL=https://sws.guenlab.de

# === EMAIL (SMTP for notifications) ===
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=your_password
# SMTP_FROM=noreply@stickwerk-studio.de
# NOTIFY_EMAIL=admin@stickwerk-studio.de
