# ============================================
# Stickwerk-Studio Environment Variables
# ============================================
# Copy this to .env and fill in your values
# Generate secrets with: openssl rand -base64 32

# === DATABASE ===
POSTGRES_PASSWORD=your_secure_password_here

# === NEXT.JS ===
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=https://sws.guenlab.de

# === DATABASE URL (auto-constructed from POSTGRES_PASSWORD) ===
# This is set in docker-compose.zima.yml automatically:
# DATABASE_URL=postgresql://stickwerk_user:${POSTGRES_PASSWORD}@db:5432/stickwerk_db
