# =============================================================================
# Stickwerk-Studio — Environment Variables
# =============================================================================
# Kopiere diese Datei nach .env und passe die Werte an:
#   cp .env.example .env
#
# Für Docker Compose:
#   docker compose --env-file .env up -d
# =============================================================================

# ---- PostgreSQL ----
# Mit docker-compose.yml (PostgreSQL im gleichen Stack):
#   DATABASE_URL=postgresql://stickwerk:DEIN_PASSWORT@db:5432/stickwerk
#
# Mit externer PostgreSQL (z.B. ZimaOS, VPS, Managed):
#   DATABASE_URL=postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://stickwerk:stickwerk_secret_2026@db:5432/stickwerk

# ---- Auth / Session ----
# SESSION_SECRET: Mindestens 32 Zeichen, zufällig!
SESSION_SECRET=stickwerk-super-secret-key-2026-change-in-production
ADMIN_USER=admin@stickwerk-studio.de
ADMIN_PASSWORD=test123

# ---- Site URLs ----
# Öffentliche URLs der Seite (für SEO, Sitemap, Links)
SITE_URL=http://localhost:3034

# ---- PostgreSQL Password (nur für docker-compose.yml) ----
# Wird sowohl für den PostgreSQL-Container als auch für DATABASE_URL verwendet.
# Wenn du das änderst, muss DATABASE_URL oben entsprechend aktualisiert werden.
POSTGRES_PASSWORD=stickwerk_secret_2026

# ---- Sentry (Error Tracking) ----
# https://sentry.io - kostenloser Account reicht
# Plattform bei Projekt-Setup: "Next.js"
#
# Runtime DSNs (Browser + Server + Edge) — DSN ist public, gefahrlos im Repo
SENTRY_DSN=https://390985695bc2d6d915f88f5f7a97220b@o4511455077007360.ingest.de.sentry.io/4511523279011920
NEXT_PUBLIC_SENTRY_DSN=https://390985695bc2d6d915f88f5f7a97220b@o4511455077007360.ingest.de.sentry.io/4511523279011920
#
# Build-time source map upload (für lesbare Production-Stack-Traces)
# Token: sentry.io → Settings → Auth Tokens → Create (scopes: project:releases, org:read)
# SENTRY_AUTH_TOKEN=sntrys_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=stickwerk-studio

# ---- SMTP / E-Mail (optional) ----
# Für Benachrichtigungen bei neuen Anfragen
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=deine@email.de
# SMTP_PASS=dein-app-passwort
# SMTP_FROM=deine@email.de
# NOTIFY_EMAIL=admin@stickwerk-studio.de
