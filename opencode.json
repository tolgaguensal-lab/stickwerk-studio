{
  "$schema": "https://opencode.ai/config.json",
  "permission": "allow",
  "plugin": ["superpowers@git+https://github.com/obra/superpowers.git"],
  "mcp": {
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"],
      "enabled": true
    }
  },
  "provider": {
    "arliai": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "ArliAI",
      "options": {
        "baseURL": "https://api.arliai.com/v1"
      },
      "models": {
        "Qwen3.5-27B-Omega-Evolution-v2.2-Derestricted-Lite": {
          "name": "Qwen3.5 27B Omega Evolution Lite",
          "limit": {
            "context": 262144,
            "output": 16384
          }
        },
        "Mistral-Medium-3.5-128B": {
          "name": "Mistral Medium 3.5 128B",
          "limit": {
            "context": 131072,
            "output": 16384
          }
        },
        "Gemma-4-31B-it": {
          "name": "Gemma 4 31B Instruction Tuned",
          "limit": {
            "context": 262144,
            "output": 32768
          }
        }
      }
    }
  },
  "model": "arliai/Qwen3.5-27B-Omega-Evolution-v2.2-Derestricted-Lite",
  "watcher": {
    "ignore": [
      "node_modules/**",
      ".next/**",
      "dist/**",
      "build/**",
      ".git/**",
      "playwright-report/**",
      "test-results/**"
    ]
  }
}
